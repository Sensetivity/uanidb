# Git
.git
.gitignore
.gitattributes

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Dependencies (will be installed in container)
/node_modules
/vendor

# Build artifacts
/public/build
/public/hot
/public/storage

# Environment files (use docker-specific env)
.env
.env.backup
.env.production

# Logs and cache
/storage/logs/*
!/storage/logs/.gitkeep
/storage/framework/cache/*
!/storage/framework/cache/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/framework/views/*
!/storage/framework/views/.gitkeep

# Testing
/coverage
.phpunit.result.cache
phpunit.xml

# Docker
docker-compose.override.yml

# Documentation
*.md
!README.md
LICENSE
